{
  "name": "synapse-browser",
  "version": "1.0.0",
  "main": "dist/main/background.js",
  "description": "AI-First Productivity Browser",
  "author": "Manus AI",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite preview",
    "build": "electron-vite build",
    "preview": "vite preview",
    "pack": "electron-builder --publish never",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.synapse.browser",
    "productName": "Synapse Browser",
    "files": [
      "dist",
      "node_modules"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sqlite3": "^6.0.1",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "zustand": "^5.0.14"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "vite": "^8.1.3"
  }
}
