{
  "type": "module",
  "name": "synapse-browser",
  "version": "1.0.0",
  "main": "out/main/background.js",
  "description": "AI-First Productivity Browser",
  "author": "Rahul S R",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc src/main/*.ts --ignoreConfig --outDir out/main --module esnext --target es2020 --moduleResolution bundler --lib es2020 --skipLibCheck && tsc src/main/preload.ts --ignoreConfig --outDir out/preload --module esnext --target es2020 --moduleResolution bundler --lib es2020 --skipLibCheck",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --publish never",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.synapse.browser",
    "productName": "Synapse Browser",
    "files": [
      "out",
      "dist",
      "node_modules"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^8.2.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sqlite3": "^6.0.1",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^2.0.5",
    "wait-on": "^7.2.0",
    "zustand": "^5.0.14"
  }
}
